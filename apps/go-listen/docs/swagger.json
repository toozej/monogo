{
    "schemes": [
        "http",
        "https"
    ],
    "swagger": "2.0",
    "info": {
        "description": "Manage Spotify incoming playlists, add artists, and discover artists by scraping web pages.\nWhen HTTP Basic Auth is configured, it protects the API and Swagger UI. POST operations also require a token from GET /api/csrf-token in the X-CSRF-Token header.",
        "title": "go-listen API",
        "contact": {},
        "version": "1.0"
    },
    "basePath": "/",
    "paths": {
        "/api/add-artist": {
            "post": {
                "security": [
                    {
                        "BasicAuth": []
                    }
                ],
                "description": "Adds an artist's top tracks to a Spotify playlist. Supply force=true to add tracks despite duplicate detection.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "playlists"
                ],
                "summary": "Add an artist to a playlist",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Token returned by GET /api/csrf-token",
                        "name": "X-CSRF-Token",
                        "in": "header",
                        "required": true
                    },
                    {
                        "description": "Artist and target playlist",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/types.AddArtistRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/server.SwaggerAddArtistResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/types.APIResponse"
                        }
                    },
                    "401": {
                        "description": "Basic authentication failed or Spotify reauthorization required",
                        "schema": {
                            "$ref": "#/definitions/types.APIResponse"
                        }
                    },
                    "403": {
                        "description": "Invalid or missing CSRF token",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "429": {
                        "description": "Rate limit exceeded",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/types.APIResponse"
                        }
                    }
                }
            }
        },
        "/api/auth-status": {
            "get": {
                "security": [
                    {
                        "BasicAuth": []
                    }
                ],
                "description": "Reports whether the server has an authenticated Spotify session and, when needed, returns the Spotify authorization URL.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "authentication"
                ],
                "summary": "Get Spotify authentication status",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/server.SwaggerAuthStatusResponse"
                        }
                    },
                    "401": {
                        "description": "Basic authentication failed",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "429": {
                        "description": "Rate limit exceeded",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/api/csrf-token": {
            "get": {
                "security": [
                    {
                        "BasicAuth": []
                    }
                ],
                "description": "Returns a token for the X-CSRF-Token header required by state-changing API operations.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "security"
                ],
                "summary": "Create a CSRF token",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/server.SwaggerCSRFTokenResponse"
                        }
                    },
                    "401": {
                        "description": "Basic authentication failed",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "429": {
                        "description": "Rate limit exceeded",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/types.APIResponse"
                        }
                    }
                }
            }
        },
        "/api/playlists": {
            "get": {
                "security": [
                    {
                        "BasicAuth": []
                    }
                ],
                "description": "Retrieves Spotify playlists from the Incoming folder, optionally filtered by name.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "playlists"
                ],
                "summary": "List incoming playlists",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Case-insensitive playlist name filter",
                        "name": "search",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/server.SwaggerPlaylistsResponse"
                        }
                    },
                    "401": {
                        "description": "Basic authentication failed or Spotify reauthorization required",
                        "schema": {
                            "$ref": "#/definitions/types.APIResponse"
                        }
                    },
                    "429": {
                        "description": "Rate limit exceeded",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/types.APIResponse"
                        }
                    }
                }
            }
        },
        "/api/scrape-artists": {
            "post": {
                "security": [
                    {
                        "BasicAuth": []
                    }
                ],
                "description": "Extracts artist names from a web page, matches them against Spotify, and adds their top tracks to a playlist.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "scraping"
                ],
                "summary": "Scrape and add artists",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Token returned by GET /api/csrf-token",
                        "name": "X-CSRF-Token",
                        "in": "header",
                        "required": true
                    },
                    {
                        "description": "Source page and target playlist",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/types.ScrapeArtistsRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/server.SwaggerScrapeArtistsResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/types.APIResponse"
                        }
                    },
                    "401": {
                        "description": "Basic authentication failed or Spotify reauthorization required",
                        "schema": {
                            "$ref": "#/definitions/types.APIResponse"
                        }
                    },
                    "403": {
                        "description": "Invalid or missing CSRF token",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "429": {
                        "description": "Rate limit exceeded",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/types.APIResponse"
                        }
                    },
                    "503": {
                        "description": "Scraper service is unavailable",
                        "schema": {
                            "$ref": "#/definitions/types.APIResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "scraper.ArtistMatchResult": {
            "type": "object",
            "properties": {
                "artist": {
                    "$ref": "#/definitions/types.Artist"
                },
                "confidence": {
                    "type": "number"
                },
                "error": {
                    "type": "string"
                },
                "matched": {
                    "type": "boolean"
                },
                "query": {
                    "type": "string"
                },
                "tracks_added": {
                    "type": "integer"
                },
                "was_duplicate": {
                    "type": "boolean"
                }
            }
        },
        "scraper.ScrapeResult": {
            "type": "object",
            "properties": {
                "artists_found": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "css_selector": {
                    "type": "string"
                },
                "duplicate_count": {
                    "type": "integer"
                },
                "errors": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "failure_count": {
                    "type": "integer"
                },
                "match_results": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/scraper.ArtistMatchResult"
                    }
                },
                "message": {
                    "type": "string"
                },
                "success_count": {
                    "type": "integer"
                },
                "total_tracks_added": {
                    "type": "integer"
                },
                "url": {
                    "type": "string"
                }
            }
        },
        "server.SwaggerAddArtistResponse": {
            "type": "object",
            "properties": {
                "data": {
                    "$ref": "#/definitions/types.AddResult"
                },
                "is_duplicate": {
                    "type": "boolean"
                },
                "message": {
                    "type": "string"
                },
                "success": {
                    "type": "boolean"
                }
            }
        },
        "server.SwaggerAuthStatusData": {
            "type": "object",
            "properties": {
                "auth_url": {
                    "type": "string"
                },
                "authenticated": {
                    "type": "boolean"
                }
            }
        },
        "server.SwaggerAuthStatusResponse": {
            "type": "object",
            "properties": {
                "data": {
                    "$ref": "#/definitions/server.SwaggerAuthStatusData"
                },
                "success": {
                    "type": "boolean"
                }
            }
        },
        "server.SwaggerCSRFTokenResponse": {
            "type": "object",
            "properties": {
                "csrf_token": {
                    "type": "string"
                }
            }
        },
        "server.SwaggerPlaylistsResponse": {
            "type": "object",
            "properties": {
                "data": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/types.Playlist"
                    }
                },
                "success": {
                    "type": "boolean"
                }
            }
        },
        "server.SwaggerScrapeArtistsResponse": {
            "type": "object",
            "properties": {
                "data": {
                    "$ref": "#/definitions/scraper.ScrapeResult"
                },
                "error": {
                    "type": "string"
                },
                "success": {
                    "type": "boolean"
                }
            }
        },
        "types.APIResponse": {
            "type": "object",
            "properties": {
                "data": {},
                "error": {
                    "type": "string"
                },
                "success": {
                    "type": "boolean"
                }
            }
        },
        "types.AddArtistRequest": {
            "type": "object",
            "required": [
                "artist_name",
                "playlist_id"
            ],
            "properties": {
                "artist_name": {
                    "type": "string",
                    "maxLength": 100,
                    "minLength": 1
                },
                "force": {
                    "type": "boolean"
                },
                "playlist_id": {
                    "type": "string"
                }
            }
        },
        "types.AddResult": {
            "type": "object",
            "properties": {
                "artist": {
                    "$ref": "#/definitions/types.Artist"
                },
                "message": {
                    "type": "string"
                },
                "playlist": {
                    "$ref": "#/definitions/types.Playlist"
                },
                "success": {
                    "type": "boolean"
                },
                "tracks_added": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/types.Track"
                    }
                },
                "was_duplicate": {
                    "type": "boolean"
                }
            }
        },
        "types.Artist": {
            "type": "object",
            "properties": {
                "genres": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "id": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                },
                "uri": {
                    "type": "string"
                }
            }
        },
        "types.Playlist": {
            "type": "object",
            "properties": {
                "embed_url": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "is_incoming": {
                    "type": "boolean"
                },
                "name": {
                    "type": "string"
                },
                "track_count": {
                    "type": "integer"
                },
                "uri": {
                    "type": "string"
                }
            }
        },
        "types.ScrapeArtistsRequest": {
            "type": "object",
            "required": [
                "playlist_id",
                "url"
            ],
            "properties": {
                "css_selector": {
                    "type": "string",
                    "maxLength": 500
                },
                "force": {
                    "type": "boolean"
                },
                "playlist_id": {
                    "type": "string"
                },
                "url": {
                    "type": "string"
                }
            }
        },
        "types.Track": {
            "type": "object",
            "properties": {
                "artists": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/types.Artist"
                    }
                },
                "duration_ms": {
                    "type": "integer"
                },
                "id": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                },
                "uri": {
                    "type": "string"
                }
            }
        }
    },
    "securityDefinitions": {
        "BasicAuth": {
            "type": "basic"
        }
    }
}