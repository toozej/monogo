GITHUB_TOKEN=XXXX
GITHUB_USERNAME=XXXX
GITHUB_GHCR_TOKEN=XXXX
QUAY_USERNAME=XXXX
QUAY_TOKEN=XXXX
DOCKERHUB_USERNAME=XXXX
DOCKERHUB_TOKEN=XXXX
SNYK_TOKEN=XXXX

# Select exactly one music provider: spotify or youtube.
MUSIC_CLIENT=spotify

# Spotify API Configuration (required only when MUSIC_CLIENT=spotify)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8080/callback
SPOTIFY_PLAYLIST_NAME_PREFIX=KMHD
# Path where Spotify authentication token is stored (supports ~ for home directory)
SPOTIFY_TOKEN_FILE_PATH=~/.config/kmhd2playlist/spotify_token.json

# YouTube Music API Configuration (required only when MUSIC_CLIENT=youtube)
# Copy headers from an authenticated POST /browse request to
# auth/youtubemusic-headers.json. See README for the required JSON format.
# The Docker Compose configuration mounts ./auth at /app/auth.
YOUTUBEMUSIC_AUTH_FILE_PATH=/app/auth/youtubemusic-headers.json
# YOUTUBEMUSIC_COOKIE='SID=...; HSID=...; SAPISID=...' # Legacy fallback only
YOUTUBEMUSIC_PLAYLIST_NAME_PREFIX=KMHD
YOUTUBEMUSIC_TOKEN_FILE_PATH=~/.config/kmhd2playlist/youtubemusic_token.json

# KMHD API Configuration
KMHD_API_ENDPOINT=https://www.kmhd.org/pf/api/v3/content/fetch/playlist
KMHD_HTTP_TIMEOUT=30

# Server Configuration
SERVER_HOST=127.0.0.1
SERVER_PORT=8080
