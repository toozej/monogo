[[- $app := ds "app" -]]
[[- /* Docker repository names must be lower-case (e.g. RSSFFS -> rssffs) */ -]]
---
services:
  [[$app.name]]:
    container_name: [[$app.name]]
    image: toozej/[[ strings.ToLower $app.name ]]:latest
[[- if index $app "composeUser" ]]
    user: "[[$app.composeUser]]"
[[- end ]]
[[- if index $app "composeRestart" ]]
    restart: "[[$app.composeRestart]]"
[[- else ]]
    restart: unless-stopped
[[- end ]]
    security_opt:
      - no-new-privileges:true
    read_only: true
[[- if index $app "composeEnvironment" ]]
    environment:
[[- range $app.composeEnvironment ]]
      - "[[.]]"
[[- end ]]
[[- end ]]
[[- if index $app "composeVolumes" ]]
    volumes:
[[- range $app.composeVolumes ]]
      - "[[.]]"
[[- end ]]
[[- end ]]
    labels:
      - "traefik.enable=false"
      # labels below for publishing as web service
      # - "traefik.docker.network=traefik"
      # - "traefik.http.routers.[[$app.name]].rule=Host(`[[$app.name]].test`)"
      # - "traefik.http.routers.[[$app.name]].middlewares=http-redirect-https@file,headers@file"
      # - "traefik.http.routers.[[$app.name]]-secure.entrypoints=https"
      # - "traefik.http.routers.[[$app.name]]-secure.rule=Host(`[[$app.name]].test`)"
      # - "traefik.http.routers.[[$app.name]]-secure.middlewares=headers@file"
      # - "traefik.http.routers.[[$app.name]]-secure.tls=true"
