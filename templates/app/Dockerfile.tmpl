[[- $app := ds "app" -]]
[[- $cgo := "0" -]]
[[- if conv.ToBool (index $app "cgoEnabled") -]][[- $cgo = "1" -]][[- end -]]
[[- /* CGO binaries are dynamically linked, so they need a glibc runtime instead of scratch. */ -]]
[[- $runtime := "scratch" -]]
[[- if eq $cgo "1" -]][[- $runtime = "debian:trixie-slim" -]][[- end -]]
[[- if index $app "runtimeImage" -]][[- $runtime = $app.runtimeImage -]][[- end -]]
[[- if conv.ToBool (index $app "distrolessOnly") -]]
[[- $runtime = $app.distrolessImage -]]
[[- if eq $cgo "1" -]][[- $runtime = strings.ReplaceAll "static-" "base-" $runtime -]][[- end -]]
[[- end -]]
# setup project and deps
FROM [[$app.goImage]] AS init

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

WORKDIR /workspace/

COPY go.mod* go.sum* ./
RUN go mod download

# Copy only the selected app and shared packages so unrelated apps stay out of the build context
COPY [[$app.path]] ./[[$app.path]]
COPY pkg ./pkg

FROM init AS vet
SHELL ["/bin/bash", "-o", "pipefail", "-c"]
RUN go vet ./[[$app.path]]/... ./pkg/...

# run tests
FROM init AS test
SHELL ["/bin/bash", "-o", "pipefail", "-c"]
RUN go test -coverprofile c.out -v ./[[$app.path]]/... ./pkg/... && \
    echo "Statements missing coverage" && \
    grep -v -e " 1$" c.out

# build binary
FROM init AS build
SHELL ["/bin/bash", "-o", "pipefail", "-c"]
ARG VERSION=unknown
ARG COMMIT=unknown
ARG BRANCH=unknown
ARG BUILT_AT=unknown
ARG BUILDER=unknown

RUN LDFLAGS="-s -w -X github.com/toozej/monogo/pkg/version.Version=${VERSION} -X github.com/toozej/monogo/pkg/version.Commit=${COMMIT} -X github.com/toozej/monogo/pkg/version.Branch=${BRANCH} -X github.com/toozej/monogo/pkg/version.BuiltAt=${BUILT_AT} -X github.com/toozej/monogo/pkg/version.Builder=${BUILDER}" && \
    CGO_ENABLED=[[$cgo]] go build -o /out/[[$app.binary]] -ldflags="${LDFLAGS}" ./[[$app.mainPath]]

# runtime image
FROM [[$runtime]]
# Copy our executable.
COPY --from=build /out/[[$app.binary]] /go/bin/[[$app.binary]]
# Expose port for publishing as web service
[[- if index $app "port" ]]
EXPOSE [[$app.port]]
[[- else ]]
# EXPOSE 8081
[[- end ]]
# Run the binary.
USER 65532:65532
ENTRYPOINT ["/go/bin/[[$app.binary]]"]
